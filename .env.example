# Copiá este archivo como .env y completá los valores.
# El archivo .env NUNCA se sube al repositorio (está en .gitignore).

# Generá una clave nueva, por ejemplo con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambiame-por-una-clave-secreta

# True solo en desarrollo. En producción SIEMPRE False.
DJANGO_DEBUG=True

# Qué módulo de settings usar.
DJANGO_SETTINGS_MODULE=config.settings.development

# Hosts permitidos, separados por coma.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Conexión a PostgreSQL en formato URL.
# Ejemplo local: postgres://usuario:password@localhost:5432/acopio
DATABASE_URL=postgres://acopio:acopio@localhost:5432/acopio
